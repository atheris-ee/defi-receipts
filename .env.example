# defi-receipts configuration — copy to .env and edit. Nothing here is required to run a
# read-only scan; everything is optional and has a sane default.

# --- Database (realization layer) ---------------------------------------------------------------
# The JS shells out to psql for the realization-feedback read and the dashboard's 24h diff.
RECEIPTS_PSQL="psql -d defi -U defi"
# Standard libpq vars used by the Postgres ingest scripts:
PGHOST=localhost
PGPORT=5432
PGDATABASE=defi
PGUSER=defi
# PGPASSWORD=                 # if your Postgres requires a password

# --- Paths (defaults are repo-relative; override for a system install) --------------------------
# RECEIPTS_DATA_DIR=./scanner/data       # where the scanner writes *.json
# ARCHIVE_DIR=./archive                  # where archive-scan.sh snapshots scans
# RECEIPTS_AGENT_DIR=./agent             # dev-agent workspace/state

# --- Telegram alerter (optional; the alerter no-ops cleanly without these) ----------------------
# TELEGRAM_BOT_TOKEN=123456:ABC...       # OR point at a file:
# TELEGRAM_BOT_TOKEN_FILE=./secrets/telegram-bot-token
# TELEGRAM_CHAT_ID=                      # your chat or channel id (required to actually send)

# --- RPC for portfolio/NAV reads (optional; public RPCs work for read-only scanning) ------------
# A paid RPC key (e.g. DRPC) improves portfolio + NAV coverage. Put `DRPC_KEY=...` in the file below.
# DRPC_KEY_FILE=./secrets/drpc.env


# --- Dashboard --------------------------------------------------------------------------------
DASHBOARD_PORT=8847
# DASHBOARD_TOKEN=                       # if set, dashboard requires ?k=<token>
